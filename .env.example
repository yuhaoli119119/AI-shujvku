# PostgreSQL 配置 (Docker 部署时使用)
POSTGRES_DB=lit_ai
POSTGRES_USER=lit_ai
POSTGRES_PASSWORD=your_secure_password
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
REDIS_URL=redis://localhost:6379/0

OPENALEX_API_KEY=
UNPAYWALL_EMAIL=your_email@example.com

GROBID_URL=http://localhost:8070

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-2024-08-06

STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./data/papers

DEFAULT_RATE_LIMIT_RPS=1
MAX_DOWNLOAD_RETRIES=3

# X-MOL Cookie (从浏览器登录后获取)
XMOL_COOKIE=
