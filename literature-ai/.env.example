LITAI_APP_ENV=dev
LITAI_DATABASE_URL=postgresql+psycopg://litai_app:应用密码@192.168.1.20:5432/literature_ai?sslmode=prefer
# Set sslmode=require after TLS is enabled on the B-computer PostgreSQL server.
LITAI_FORCE_CONFIGURED_DATABASE=true
LITAI_CELERY_BROKER_URL=redis://localhost:6379/0
LITAI_CELERY_RESULT_BACKEND=redis://localhost:6379/1
LITAI_GROBID_URL=http://localhost:8070
LITAI_MINIO_ENDPOINT=localhost:9000
LITAI_MINIO_ACCESS_KEY=minioadmin
LITAI_MINIO_SECRET_KEY=minioadmin
LITAI_MINIO_BUCKET=literature-ai
LITAI_MINIO_SECURE=false
LITAI_STORAGE_ROOT=/data/storage
# Docker host path mounted to /data/storage. On A computer map \\B-PC\LitAIStorage$ to Z:\LitAIStorage first.
LITAI_HOST_STORAGE_ROOT=Z:/LitAIStorage
LITAI_USE_MINIO=false
LITAI_EMBEDDING_PROVIDER=openai_compatible
LITAI_EMBEDDING_API_BASE=https://api.openai.com/v1
LITAI_EMBEDDING_API_KEY=
LITAI_EMBEDDING_MODEL=text-embedding-3-small
LITAI_EMBEDDING_DIMENSION=1536
LITAI_DOCLING_ENABLED=true
LITAI_DOCLING_DO_OCR=false
LITAI_DOCLING_FORCE_FULL_PAGE_OCR=false
LITAI_DOCLING_NUM_THREADS=4
LITAI_DOCLING_DOCUMENT_TIMEOUT=120
# Optional: point to a prefetched Docling model directory only if it already contains models.
# Otherwise leave it unset and let Docling use its default cache directory.
# LITAI_DOCLING_ARTIFACTS_PATH=./data/docling_models
LITAI_WRITER_BACKEND=rule
LITAI_WRITER_MODEL=gpt-4.1-mini
# For OpenAI-compatible backends, prefer a base like https://host/v1 .
# The backend will append /chat/completions automatically if needed.
LITAI_WRITER_API_BASE=
LITAI_WRITER_API_KEY=
LITAI_WRITER_TIMEOUT_SECONDS=30
LITAI_WRITER_FALLBACK_BACKEND=rule
LITAI_WRITER_PROMPT_PATH=prompts/paper_writer.yaml
# Optional admin token for remote settings changes. Local requests can omit it.
LITAI_SETTINGS_ADMIN_TOKEN=
# Host user directory root for /host/users mount in docker-compose.yml.
# Windows default: /c/Users
# macOS/Linux: set this manually if you want host directory browsing.
LITAI_HOST_USERS_ROOT=/c/Users
# With the default docker-compose mount, the runtime registry and all libraries live under literature-ai/data/.
# Comma-separated whitelist for /api/libraries/browse.
LITAI_BROWSE_ROOTS=/host/users,/data,/legacy
LITAI_MCP_ENABLED=true
LITAI_MCP_SERVER_NAME=Literature AI MCP
# Format:
# source_prefix|display_name|raw_api_key|capability1,capability2;source2|display_name2|raw_api_key2|...
LITAI_MCP_API_KEYS=claude|Claude Desktop|litmcp_claude|read_papers,append_notes,propose_corrections,request_parse;admin|Admin|litmcp_admin|read_papers,append_notes,propose_corrections,request_parse,review_corrections
