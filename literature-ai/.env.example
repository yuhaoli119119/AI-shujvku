LITAI_APP_ENV=dev
# Required by docker compose. Use a URL-safe random value.
LITAI_POSTGRES_PASSWORD=replace-with-a-long-random-password
LITAI_DATABASE_URL=postgresql+psycopg://literature_ai:replace-with-a-long-random-password@localhost:5432/literature_ai
LITAI_FORCE_CONFIGURED_DATABASE=true
LITAI_ENABLE_DEPRECATED_DB_ENDPOINTS=false
LITAI_CELERY_BROKER_URL=redis://localhost:6379/0
LITAI_CELERY_RESULT_BACKEND=redis://localhost:6379/1
LITAI_GROBID_URL=http://localhost:8070
LITAI_MINIO_ENDPOINT=localhost:9000
LITAI_MINIO_ACCESS_KEY=replace-with-a-random-access-key
LITAI_MINIO_SECRET_KEY=replace-with-a-long-random-secret
LITAI_MINIO_BUCKET=literature-ai
LITAI_MINIO_SECURE=false
# Docker Compose overrides this to /data/storage and mounts ./data:/data.
# For local non-Docker runs:
# - from literature-ai/: keep ./data/storage
# - from literature-ai/backend/: use ../data/storage
LITAI_STORAGE_ROOT=./data/storage
LITAI_USE_MINIO=false
LITAI_EMBEDDING_PROVIDER=openai_compatible
LITAI_EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
LITAI_EMBEDDING_API_KEY=
LITAI_EMBEDDING_MODEL=BAAI/bge-m3
LITAI_EMBEDDING_DIMENSION=1024
LITAI_DOCLING_ENABLED=true
LITAI_DOCLING_DO_OCR=false
LITAI_DOCLING_AUTO_OCR=true
LITAI_DOCLING_FORCE_FULL_PAGE_OCR=false
LITAI_DOCLING_NUM_THREADS=4
LITAI_DOCLING_DOCUMENT_TIMEOUT=120
# Optional: point to a prefetched Docling model directory only if it already contains models.
# Otherwise leave it unset and let Docling use its default cache directory.
# LITAI_DOCLING_ARTIFACTS_PATH=./data/docling_models
LITAI_WRITER_BACKEND=rule
LITAI_WRITER_MODEL=gpt-4.1-mini
# For OpenAI-compatible backends, prefer a base like https://host/v1 .
# The backend will append /chat/completions automatically if needed.
LITAI_WRITER_API_BASE=
LITAI_WRITER_API_KEY=
LITAI_WRITER_TIMEOUT_SECONDS=30
LITAI_WRITER_FALLBACK_BACKEND=rule
LITAI_WRITER_PROMPT_PATH=prompts/paper_writer.yaml
# Owner token for non-loopback management/API access. Loopback requests are the
# trusted local Owner entry; LAN clients need this token for non-share APIs.
LITAI_OWNER_API_TOKEN=replace-with-a-long-random-owner-token
LITAI_SHARE_BIND_IP=0.0.0.0
LITAI_SHARE_PORT=8080
# Set this to the host's real LAN address so generated links are usable remotely.
LITAI_SHARE_PUBLIC_BASE_URL=http://192.168.1.50:8080
# Legacy settings token remains accepted as an Owner-token fallback.
LITAI_SETTINGS_ADMIN_TOKEN=
# Host user directory root for /host/users mount in docker-compose.yml.
# Windows default: /c/Users
# macOS/Linux: set this manually if you want host directory browsing.
LITAI_HOST_USERS_ROOT=/c/Users
# With the default docker-compose mount, the runtime registry and all libraries live under literature-ai/data/.
# Comma-separated whitelist for /api/libraries/browse.
LITAI_BROWSE_ROOTS=/host/users,/data,/legacy
LITAI_LOCAL_INGEST_ROOTS=/host/users
LITAI_EXPORTS_ENABLED=false
LITAI_MCP_ENABLED=true
LITAI_MCP_ALLOW_UNAUTHENTICATED=false
LITAI_MCP_SERVER_NAME=Literature AI MCP
# Format:
# source_prefix|display_name|raw_api_key|capability1,capability2;source2|display_name2|raw_api_key2|...
# IDE AI clients need read_papers + propose_corrections to read Codex context and import external_audit_opinion candidates.
# Add separate non-admin keys only if you want audit logs to distinguish agents such as GLM, Gemini, or Codex.
# HTTP MCP always requires a Bearer key. In-process app.mcp.* calls continue to
# use mcp_auth_context and do not use this transport key.
LITAI_MCP_API_KEYS=owner|Local Owner|replace-with-a-long-random-mcp-key|read_papers,append_notes,propose_corrections,request_parse,review_corrections,review_dft,create_share_links
